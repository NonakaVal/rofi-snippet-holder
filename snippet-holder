#!/bin/bash

LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)"

source "$LIB_DIR/config.sh"
source "$LIB_DIR/clipboard.sh"
source "$LIB_DIR/filesystem.sh"
source "$LIB_DIR/rofi_ui.sh"
source "$LIB_DIR/snippets.sh"

DATE_FORMAT=$(date +%Y-%m-%d)

load_config
ensure_dirs
write_default_config
create_default_template

main_menu() {
    local choice

    choice=$(echo -e "📁 Navegar\n🔍 Buscar\n🏷️  Buscar por tag\n🕐 Historico\n⭐ Favoritos\n📥 Exportar\n📤 Importar" | rofi_menu \
        -p "snippet-holder" \
        -mesg "Alt+1 Navegar · Alt+2 Buscar · Alt+3 Tags · Alt+4 Historico · Alt+5 Favoritos")

    case "$choice" in
        "📁 Navegar") browser "$NOTES_DIR" ;;
        "🔍 Buscar")
            local query
            query=$(rofi_menu -p "🔍 Busca global")
            [ -n "$query" ] && _search_results "$query"
            ;;
        "🏷️  Buscar por tag")
            local tag
            tag=$(rofi_menu -p "🏷️  Tag")
            [ -n "$tag" ] && _tag_results "$tag"
            ;;
        "🕐 Historico") _history_menu ;;
        "⭐ Favoritos") _favorites_menu ;;
        "📥 Exportar") _export_action ;;
        "📤 Importar") _import_action ;;
    esac
}

_search_results() {
    local query="$1"
    local results

    results="$(search_global "$query")"

    [ -z "$results" ] && { notify-send "Trechos" "Nenhum resultado para: $query"; return; }

    local selection
    selection=$(echo -ne "$results" | rofi_menu \
        -p "🔍 $query" \
        -display-columns 1)

    [ -z "$selection" ] && return

    local path
    path="$(echo "$selection" | cut -f3-)"
    [ -f "$path" ] && show_actions "$path"
}

_tag_results() {
    local tag="$1"
    local results

    results="$(search_by_tag "$tag")"

    [ -z "$results" ] && { notify-send "Trechos" "Nenhum resultado para tag: $tag"; return; }

    local selection
    selection=$(echo -ne "$results" | rofi_menu \
        -p "🏷️  $tag" \
        -display-columns 1)

    [ -z "$selection" ] && return

    local path
    path="$(echo "$selection" | cut -f3-)"
    [ -f "$path" ] && show_actions "$path"
}

_history_menu() {
    local entries

    entries="$(list_history)"

    [ -z "$entries" ] && { notify-send "Trechos" "Historico vazio."; return; }

    local selection
    selection=$(echo -ne "$entries" | rofi_menu \
        -p "🕐 Historico" \
        -display-columns 1)

    [ -z "$selection" ] && return

    local path
    path="$(echo "$selection" | cut -f3-)"
    [ -f "$path" ] && show_actions "$path"
}

_favorites_menu() {
    local entries

    entries="$(list_favorites)"

    [ -z "$entries" ] && { notify-send "Trechos" "Nenhum favorito."; return; }

    local selection
    selection=$(echo -ne "$entries" | rofi_menu \
        -p "⭐ Favoritos" \
        -display-columns 1)

    [ -z "$selection" ] && return

    local path
    path="$(echo "$selection" | cut -f3-)"
    [ -f "$path" ] && show_actions "$path"
}

_export_action() {
    local dest
    dest=$(rofi_menu -p "📥 Exportar para")
    [ -z "$dest" ] && return
    export_snippets "$dest"
}

_import_action() {
    local archive
    archive=$(rofi_menu -p "📤 Arquivo de importacao")
    [ -z "$archive" ] && return
    [ ! -f "$archive" ] && { notify-send "Trechos" "Arquivo nao encontrado."; return; }
    import_snippets "$archive"
}

browser() {
    local current_dir="$1"
    local sort_mode="${DEFAULT_SORT:-recent}"

    while true; do
        local current_label
        local entries
        local selection
        local ret
        local label
        local type
        local path
        local msg

        current_label="$(short_path "$current_dir")"

        if [ "$sort_mode" = "recent" ]; then
            msg="✚ Alt+n · 📁 Alt+g · ⇅ Alt+o · ← Alt+q · ↓"
        else
            msg="✚ Alt+n · 📁 Alt+g · ⇅ Alt+o · ← Alt+q · A"
        fi

        entries="$(list_entries "$current_dir" "$sort_mode")"

        selection=$(echo "$entries" | rofi_menu \
            -p "$current_label" \
            -display-columns 1 \
            -mesg "$msg" \
            -kb-custom-1 "Alt+n" \
            -kb-custom-2 "Alt+g" \
            -kb-custom-3 "Alt+o" \
            -kb-custom-4 "Alt+q")

        ret=$?

        case "$ret" in
            10)
                new_snippet "$current_dir"
                ;;
            11)
                local new_dir
                new_dir="$(create_group "$current_dir")" || continue
                current_dir="$new_dir"
                ;;
            12)
                if [ "$sort_mode" = "recent" ]; then
                    sort_mode="az"
                else
                    sort_mode="recent"
                fi
                ;;
            13)
                if [ "$current_dir" != "$NOTES_DIR" ]; then
                    current_dir="$(dirname "$current_dir")"
                fi
                ;;
            0)
                [ -z "$selection" ] && continue

                label="$(echo "$selection" | cut -f1)"
                type="$(echo "$selection" | cut -f2)"
                path="$(echo "$selection" | cut -f3-)"

                case "$type" in
                    "UP")
                        current_dir="$path"
                        ;;
                    "DIR")
                        current_dir="$path"
                        ;;
                    "FILE")
                        show_actions "$path"
                        [ $? -eq 99 ] && exit 0
                        ;;
                esac
                ;;
            *)
                exit 0
                ;;
        esac
    done
}

main_menu
